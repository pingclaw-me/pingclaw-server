PORT=8080

# PostgreSQL connection string. Required.
DATABASE_URL=postgres://pingclaw:pingclaw@localhost:5432/pingclaw?sslmode=disable

# Redis connection string. Required. Stores verification codes and
# location data (24h TTL).
REDIS_URL=redis://localhost:6379

# Server log file. Stdout is always written too.
LOG_FILE=logs/server.log

# SMS provider (Twilio). When unset, verification codes are logged to
# the server log instead of being SMS'd — useful for development.
# On a trial Twilio account, only phone numbers you've manually
# verified in the Twilio console can receive messages.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Sign-in rate limits (per fixed 1-hour window).
RATE_LIMIT_PHONE_PER_HOUR=3
RATE_LIMIT_IP_PER_HOUR=10
