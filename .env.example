PORT=8080

# PostgreSQL connection string. Required.
DATABASE_URL=postgres://pingclaw:pingclaw@localhost:5432/pingclaw?sslmode=disable

# Redis connection string. Required. Stores location data (24h TTL)
# and web-login codes (5 min TTL).
REDIS_URL=redis://localhost:6379

# Apple Sign in — iOS uses the bundle ID, web uses a Services ID.
APPLE_BUNDLE_ID=me.pingclaw.app

# Google Sign in — OAuth client ID is the expected JWT audience.
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=

# Rate limits.
RATE_LIMIT_IP_PER_HOUR=10
RATE_LIMIT_LOC_POST_PER_MIN=30
RATE_LIMIT_LOC_GET_PER_MIN=60

# OAuth 2.0 (for ChatGPT GPT Actions). Generate a random secret:
#   openssl rand -hex 32
OAUTH_CLIENT_ID=pingclaw-gpt
OAUTH_CLIENT_SECRET=

# ChatGPT custom GPT deep link (served to apps via GET /pingclaw/config).
CHATGPT_GPT_URL=https://chatgpt.com/g/g-69e2d7fe797c8191ab8c0356f375daca-pingclaw

# OpenClaw push delivery (optional tuning — defaults are fine)
# OPENCLAW_DELIVERY_TIMEOUT_SECONDS=10
# OPENCLAW_DELIVERY_RETRY_DELAY_SECONDS=2
