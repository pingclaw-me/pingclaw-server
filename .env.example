PORT=8080

# PostgreSQL connection string. Required.
#   Local docker-compose: postgres://pingclaw:pingclaw@postgres:5432/pingclaw?sslmode=disable
#   Native local install: postgres://localhost/pingclaw
#   Digital Ocean managed: postgres://user:pass@db-...ondigitalocean.com:25060/pingclaw?sslmode=require
DATABASE_URL=postgres://pingclaw:pingclaw@localhost:5432/pingclaw?sslmode=disable

# Redis connection string. Currently unused by the server but the
# infrastructure provisions one for future caching needs.
REDIS_URL=redis://localhost:6379

# Server log file. Stdout is always written too.
LOG_FILE=logs/server.log
